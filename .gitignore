# ============================================================
# Zentect .gitignore — 工程与运行时安全过滤
# 分类说明：不该上传的 5 类文件
#   1. 运行时用户数据 / 缓存
#   2. 构建产物 / 编译缓存
#   3. 大型二进制模型 / 资源
#   4. 敏感配置 / 凭据
#   5. IDE / 编辑器 / 系统文件
# ============================================================

# ── 1. 运行时用户数据 + 内部文档 ───────────────────────────
# 运行期生成的用户项目、帧缓存、SQLite 数据库、日志
data/
output/

# 架构 / PRD / 内部设计文档（不上传 git）
docs/

# ── 2. 构建产物 / 编译缓存 ──────────────────────────────────
# electron-vite / tsc / vitest 输出
out/
dist/
node_modules/

# TypeScript 增量编译缓存
*.tsbuildinfo

# Python 字节码缓存
__pycache__/
*.pyc

# Python 运行时构建产物
*.egg-info/
dist-packages/

# ESLint 缓存
.eslintcache

# Electron 构建产物
build/
build/*.dmg
build/*.exe
build/*.AppImage
release/

# ── 3. 大型二进制模型 + 运行时二进制 ───────────────────────
# AI 模型文件（.onnx 通常 50-500MB/个）
resources/models/**/*.onnx
resources/models/**/*.bin
resources/models/**/*.data
resources/models/**/*.zip
resources/models/**/*.7z
resources/models/**/*.tar.gz

# 嵌入模型目录内的独立 git 仓库（如 sensevoice_onnx）
resources/models/sensevoice_onnx/.git/
resources/models/sensevoice_onnx/.gitignore
resources/models/sensevoice_onnx/.gitattributes

# HuggingFace / 模型缓存
**/.cache/huggingface/

# FFmpeg 等运行时依赖（大二进制，通过 CI/CD 分发的 assets）
resources/bin/win/*.exe
resources/bin/win/*.dll
resources/bin/win/shared/
resources/bin/win/ffmpeg.exe
resources/bin/win/ffplay.exe
resources/bin/win/ffprobe.exe

# 顶层模型目录（与 resources/models 可能重复）
models/

# 资源目录中的临时文件
resources/temp/
resources/cache/
resources/logs/

# 资源目录中不需要的媒体文件（保留 bin/ 和 models/）
resources/*.png
resources/*.jpg
resources/*.jpeg
resources/*.gif
resources/*.mp4
resources/*.mov
resources/*.avi
resources/*.zip
resources/bin/win/*.zip

# ── 4. 凭据 / 敏感配置 ─────────────────────────────────────
# 环境变量凭据（如果将来使用）
.env
.env.local
.env.*.local
.env.production

# API Key 或 Token 文件
*.pem
*.key
*.cert
secrets/
credentials/

# ── 5. IDE / 编辑器 / 系统文件 ────────────────────────────
# IDE 配置（每人本地不同）
.vscode/
.idea/
*.swp
*.swo
*~

# CodeBuddy / Trae 本地状态
.trae/
.codebuddy/

# macOS
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows 空设备引用
nul
NUL

# ── 6. 日志 / 临时文件 ─────────────────────────────────────
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# temp / 编辑器临时文件
*.tmp
*.swp
*.swo

# 临时调试脚本
check_db*.py
test_demucs.py

# 编译错误日志
tsc-*-errors.txt

# 临时媒体文件
media_*.wav

# 迁移脚本
migrate_*.sql

# ── 7. 包管理器冲突标记 ────────────────────────────────────
# 如果团队统一使用 pnpm，建议移除 package-lock.json
# package-lock.json

# ── 8. 本地脚本和调试文件 ─────────────────────────────────
debug-*.md

# ── 9. Husky Git Hooks ────────────────────────────────────
# .husky/ is committed — shared git hook infrastructure

# ── 10. 包管理器配置 ──────────────────────────────────────
.npmrc
pnpm-workspace.yaml
# pnpm-lock.yaml is committed — CI uses pnpm
# /scripts/ is committed — dev scripts and test harnesses

# ── 11. 时间戳备份文件 ──────────────────────────────────
src/main/engine/capabilities/TTSProvider_*.ts
src/main/engine/capabilities/index_*.ts
src/main/engine/strategies/TTSStrategy_*.ts
src/renderer/src/pages/editor/components/steps/StepTTSSynthesis_*.tsx
src/renderer/src/pages/editor/components/steps/containers/StepTTSSynthesisView_*.tsx
src/renderer/src/pages/home/index_*.tsx
